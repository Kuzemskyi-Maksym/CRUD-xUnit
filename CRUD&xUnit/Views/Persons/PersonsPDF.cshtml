@using ServiceContracts.Enums
@model IEnumerable<PersonResponse>
@{
    Layout = null;
}

<link href="@Url.Content("~/StyleSheet.css")" rel="stylesheet" />
<h1>Persons</h1>
<table class="table w-100 mt">
    <thead>
        <tr>
            <th>Person Name</th>
            <th>Email</th>
            <th>DateOfBirth</th>
            <th>Age</th>
            <th>Country</th>
            <th>Gender</th>
            <th>Address</th>
            <th>ReceiveNewsLetters</th>
        </tr>
    </thead>
    <tbody>
        @foreach (PersonResponse person in Model)
        {
            <tr>
                <td style="width:15%">@person.PersonName</td>
                <td style="width:20%">@person.Email</td>
                <td style="width:13%">@person.DateOfBirth?.ToString("dd MMM yyyy")</td>
                <td style="width:9%">@person.Age</td>
                <td style="width:9%">@person.Country</td>
                <td style="width:10%">@person.Gender.ToString()</td>
                <td style="width:15%">@person.Address</td>
                <td style="width:20%">@person.ReceiveNewsLetters</td>
            </tr>
        }
    </tbody>
</table>